{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "dev-hub-tauri",
  "version": "0.1.0",
  "identifier": "com.dev-hub-tauri.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "dev-hub-tauri",
        "width": 1280,
        "height": 840,
        "minWidth": 1080,
        "minHeight": 680,
        "transparent": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 16,
          "y": 18
        }
      },
      {
        "label": "settings",
        "title": "Settings",
        "width": 760,
        "height": 560,
        "minWidth": 680,
        "minHeight": 500,
        "resizable": false,
        "visible": false,
        "create": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
